  "query": "WITH entities AS (SELECT id FROM cala_journals WHERE id = ANY($1)) SELECT i.id AS \"entity_id: Repo__Id\", e.sequence, e.event, CASE WHEN $2 THEN e.context ELSE NULL::jsonb END as \"context: es_entity::ContextData\", e.recorded_at, NULL::jsonb as \"forgettable_payload?\" FROM entities i JOIN cala_journal_events e ON i.id = e.id ORDER BY i.id, e.sequence",
