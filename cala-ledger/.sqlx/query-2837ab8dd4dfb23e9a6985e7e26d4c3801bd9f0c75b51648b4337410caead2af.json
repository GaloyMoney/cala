  "query": "WITH entities AS (SELECT id FROM cala_accounts WHERE eventually_consistent = $1) SELECT i.id AS \"entity_id: Repo__Id\", e.sequence, e.event, CASE WHEN $2 THEN e.context ELSE NULL::jsonb END as \"context: es_entity::ContextData\", e.recorded_at, NULL::jsonb as \"forgettable_payload?\" FROM entities i JOIN cala_account_events e ON i.id = e.id ORDER BY i.id, e.sequence",
